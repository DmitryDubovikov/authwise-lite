# Все переменные — через Settings с префиксом AW_ (сквозной контракт №7).
# replay = $0 и дефолт; record/live — деньги, только по явной просьбе (правило 4).
# AW_LLM_MODE=replay
# AW_CASSETTE_SET=smoke
# AW_RETRY_LIMIT=2
# AW_TIER_CLASSIFY=cheap
# AW_TIER_POLICY_CHECK=cheap
# AW_OPENAI_API_KEY=sk-...
# AW_MLFLOW_TRACKING_URI=http://localhost:5051
